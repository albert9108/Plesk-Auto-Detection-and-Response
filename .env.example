# Copy to .env and fill in. All vars are prefixed ADR_.

# Shared secret UptimeRobot must append as ?token=... and chat callbacks must send.
ADR_WEBHOOK_TOKEN=change-me

# UptimeRobot prober IPs (comma-separated). Used to detect "we banned our monitor".
# Get the current list from UptimeRobot's docs/dashboard.
ADR_PROBE_IPS=

# Seconds to wait for a human on an APPROVAL-tier action before auto-denying.
ADR_APPROVAL_TIMEOUT=300

# ---- AI fallback (OPTIONAL). Without this the system still runs the playbook. ----
# ANTHROPIC_API_KEY=sk-ant-...
# ADR_AI_MODEL=claude-sonnet-4-6

# ---- Notifiers (set any subset; if none set, falls back to console output) ----
# ADR_TELEGRAM_BOT_TOKEN=
# ADR_TELEGRAM_CHAT_ID=
# ADR_DISCORD_WEBHOOK_URL=
# ADR_TEAMS_WEBHOOK_URL=
# Public base URL of this orchestrator (used by Teams approval buttons).
# ADR_PUBLIC_URL=https://adr.example.com

# Audit DB path.
ADR_AUDIT_DB=adr-audit.sqlite

# ---- Multi-server (off-box orchestrator) ----
# Path to the server inventory. If set, alerts route to the box hosting the domain.
# If unset, the orchestrator runs in-process ("everything on the box").
# ADR_SERVERS_FILE=servers.yaml

# ---- MCP server (on each Plesk box) ----
# ADR_USE_SUDO=1
# stdio = co-located MCP for Claude; http = authenticated URL for the orchestrator.
# ADR_MCP_TRANSPORT=stdio
# Bearer token the orchestrator must present when ADR_MCP_TRANSPORT=http. REQUIRED in http mode.
# ADR_MCP_TOKEN=
# ADR_MCP_HTTP_HOST=0.0.0.0
# ADR_MCP_HTTP_PORT=8765
